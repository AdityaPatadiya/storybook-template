{
  "name": "@octo/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@octo/eslint-config": "workspace:*",
    "@octo/tsconfig": "workspace:*",
    "@types/node": "^22.7.5",
    "eslint": "^8.57.1",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
